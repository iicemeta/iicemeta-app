---
import { siteConfig } from '../site.config';
import { Icon } from 'astro-icon/components';

const { footer, theme, socialLinks } = siteConfig;
---

{footer.enabled && (
  <footer 
    class="py-12 px-6 md:px-12 border-t"
    style={`border-color: ${theme.colors.border}`}
  >
    <div class="max-w-6xl mx-auto">
      <!-- 页脚链接分组（如果有的话） -->
      {footer.links && footer.links.length > 0 && (
        <div class="flex flex-wrap justify-center gap-12 mb-8">
          {footer.links.map(group => (
            <div>
              <h4 
                class="text-sm font-medium mb-4"
                style={`color: ${theme.colors.text}`}
              >
                {group.title}
              </h4>
              <ul class="space-y-2">
                {group.items.map(link => (
                  <li>
                    <a 
                      href={link.href}
                      class="text-sm transition-colors duration-300"
                      style={`color: ${theme.colors.textMuted}`}
                      onmouseenter={`this.style.color='${theme.colors.primary}'`}
                      onmouseleave={`this.style.color='${theme.colors.textMuted}'`}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}
      
      <!-- 社交图标 -->
      {socialLinks && socialLinks.length > 0 && (
        <div class="flex justify-center gap-4 mb-6">
          {socialLinks.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-lg transition-all duration-300 hover:scale-110"
              style={`color: ${theme.colors.textMuted}`}
              onmouseenter={`this.style.color='${theme.colors.primary}'`}
              onmouseleave={`this.style.color='${theme.colors.textMuted}'`}
              aria-label={link.name}
            >
              <Icon name={link.icon} size={20} />
            </a>
          ))}
        </div>
      )}
      
      <!-- 版权信息 -->
      <div class="text-center">
        <p 
          class="text-sm"
          style={`color: ${theme.colors.textMuted}`}
        >
          {footer.copyright}
        </p>
      </div>
    </div>
  </footer>
)}
