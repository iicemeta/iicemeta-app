---
import { siteConfig } from '../site.config';
import { Icon } from 'astro-icon/components';

const { footer, theme, socialLinks } = siteConfig;
---

{footer.enabled && (
  <footer
    class="py-8 sm:py-12 border-t reveal"
    style={`border-color: ${theme.colors.border}`}
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6 md:px-12">
      <!-- 页脚链接分组（如果有的话） -->
      {footer.links && footer.links.length > 0 && (
        <div class="flex flex-wrap justify-center gap-8 sm:gap-12 mb-6 sm:mb-8">
          {footer.links.map((group: { title: string; items: { label: string; href: string }[] }) => (
            <div class="reveal-scale reveal-delay-1 text-center sm:text-left">
              <h4
                class="text-xs sm:text-sm font-medium mb-3 sm:mb-4"
                style={`color: ${theme.colors.text}`}
              >
                {group.title}
              </h4>
              <ul class="space-y-2">
                {group.items.map((link: { label: string; href: string }) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-xs sm:text-sm link-underline transition-colors duration-300"
                      style={`color: ${theme.colors.textMuted}`}
                      onmouseenter={`this.style.color='${theme.colors.primary}'`}
                      onmouseleave={`this.style.color='${theme.colors.textMuted}'`}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}

      <!-- 社交图标 -->
      {socialLinks && socialLinks.length > 0 && (
        <div class="flex justify-center gap-3 sm:gap-4 mb-4 sm:mb-6 reveal-scale reveal-delay-2">
          {socialLinks.map((link, index) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="tag-bounce p-2 rounded-lg transition-all duration-300 hover:scale-110"
              style={`color: ${theme.colors.textMuted}; animation-delay: ${index * 0.1}s;`}
              onmouseenter={`this.style.color='${theme.colors.primary}'`}
              onmouseleave={`this.style.color='${theme.colors.textMuted}'`}
              aria-label={link.name}
            >
              <Icon name={link.icon} size={18} class="sm:w-5 sm:h-5" />
            </a>
          ))}
        </div>
      )}

      <!-- 版权信息 -->
      <div class="text-center reveal-scale reveal-delay-3">
        <p
          class="text-xs sm:text-sm"
          style={`color: ${theme.colors.textMuted}`}
        >
          {footer.copyright}
        </p>
      </div>
    </div>
  </footer>
)}
