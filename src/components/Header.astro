---
import { siteConfig } from '../site.config';

const { navbar, theme } = siteConfig;
const currentPath = Astro.url.pathname;
---

<header class="py-8 px-6 md:px-12">
  <nav class="flex justify-between items-center max-w-6xl mx-auto">
    <!-- Logo/站点标题 -->
    <a 
      href="/" 
      class="text-2xl font-serif hover:text-[#E74C3C] transition-colors duration-300"
      style={`color: ${theme.colors.text}`}
    >
      {navbar.title}
    </a>
    
    <!-- 导航链接 -->
    <ul class="flex gap-12">
      {navbar.items.map(item => (
        <li>
          <a
            href={item.to}
            class="text-sm tracking-wide transition-all duration-300 hover:translate-x-1 inline-block"
            style={`
              color: ${currentPath === item.to ? theme.colors.primary : theme.colors.textMuted};
            `}
            onmouseenter={`this.style.color='${currentPath === item.to ? theme.colors.primary : theme.colors.text}'`}
            onmouseleave={`this.style.color='${currentPath === item.to ? theme.colors.primary : theme.colors.textMuted}'`}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
