---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, category, tags, description, readingTime } = post.data;

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group py-8 border-b border-[#E8E8E8] last:border-b-0 card-lift">
  <a href={`/posts/${post.id}`} class="block">
    <div class="flex flex-col gap-4">
      {/* 标题 - 悬停时变色并右移 */}
      <h2 class="text-2xl md:text-3xl font-serif text-[#1A1A1A] group-hover:text-[#E74C3C] transition-all duration-300 group-hover:translate-x-2">
        {title}
      </h2>

      {/* 元信息 - 悬停时颜色变化 */}
      <div class="flex items-center gap-4 text-sm text-[#6B6B6B] group-hover:text-[#1A1A1A] transition-colors duration-300">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="opacity-50">·</span>
        <span>{category}</span>
        {readingTime && (
          <>
            <span class="opacity-50">·</span>
            <span>{readingTime}</span>
          </>
        )}
      </div>

      {/* 摘要 - 悬停时颜色加深 */}
      <p class="text-[#6B6B6B] leading-relaxed line-clamp-2 group-hover:text-[#4A4A4A] transition-colors duration-300">
        {description}
      </p>

      {/* 标签 - 弹跳效果 */}
      {tags.length > 0 && (
        <div class="flex gap-2 flex-wrap">
          {tags.map((tag, index) => (
            <span
              class="tag-bounce text-xs px-3 py-1 bg-[#E8E8E8] text-[#6B6B6B] rounded-full group-hover:bg-[#E74C3C] group-hover:text-white transition-all duration-300"
              style={`transition-delay: ${index * 50}ms;`}
            >
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
