---
import '../styles/global.css';
import '../styles/animations.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../site.config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  modifiedDate?: Date;
  author?: string;
  tags?: string[];
  noindex?: boolean;
  canonicalUrl?: string;
}

const { 
  title = siteConfig.title,
  description = siteConfig.description,
  image = `${siteConfig.url}/avatar.webp`,
  type = 'website',
  publishDate,
  modifiedDate,
  author = siteConfig.author.name,
  tags = [],
  noindex = false,
  canonicalUrl,
} = Astro.props;

const currentUrl = new URL(Astro.url.pathname, siteConfig.url).toString();
const canonical = canonicalUrl || currentUrl;

const pageTitle = title === siteConfig.title 
  ? siteConfig.title 
  : `${title} · ${siteConfig.title}`;

const formattedPublishDate = publishDate?.toISOString();
const formattedModifiedDate = modifiedDate?.toISOString() || formattedPublishDate;

const schemaOrgData = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'BlogPosting' : 'WebSite',
  ...(type === 'article' ? {
    headline: title,
    description: description,
    url: canonical,
    datePublished: formattedPublishDate,
    dateModified: formattedModifiedDate,
    author: {
      '@type': 'Person',
      name: author,
    },
    publisher: {
      '@type': 'Organization',
      name: siteConfig.title,
      logo: {
        '@type': 'ImageObject',
        url: `${siteConfig.url}/avatar.webp`,
      },
    },
    image: image.startsWith('http') ? image : `${siteConfig.url}${image}`,
    keywords: tags.join(', '),
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': canonical,
    },
  } : {
    name: siteConfig.title,
    description: siteConfig.description,
    url: siteConfig.url,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${siteConfig.url}/search?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  }),
};
---

<!DOCTYPE html>
<html lang={siteConfig.language}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  
  {/* 基础 Meta */}
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content={author} />
  <meta name="generator" content="Astro" />
  
  {/* Robots */}
  {noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow" />
  )}
  
  {/* Canonical URL */}
  <link rel="canonical" href={canonical} />
  
  {/* Favicon */}
  <link rel="icon" type="image/svg+xml" href={siteConfig.favicon} />
  <link rel="apple-touch-icon" href="/avatar.webp" />
  
  {/* Open Graph */}
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={siteConfig.title} />
  <meta property="og:type" content={type} />
  <meta property="og:image" content={image.startsWith('http') ? image : `${siteConfig.url}${image}`} />
  <meta property="og:image:alt" content={title} />
  <meta property="og:locale" content="zh_CN" />
  
  {/* Twitter Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image.startsWith('http') ? image : `${siteConfig.url}${image}`} />
  <meta name="twitter:image:alt" content={title} />
  
  {/* 文章特定 Meta */}
  {type === 'article' && formattedPublishDate && (
    <meta property="article:published_time" content={formattedPublishDate} />
  )}
  {type === 'article' && formattedModifiedDate && (
    <meta property="article:modified_time" content={formattedModifiedDate} />
  )}
  {type === 'article' && tags.map((tag) => (
    <meta property="article:tag" content={tag} />
  ))}
  
  {/* Schema.org JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrgData)} />
  
  {/* 字体预加载 */}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
  
  {/* RSS Feed */}
  <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} - RSS Feed`} href={`${siteConfig.url}/rss.xml`} />
</head>
<body
  class="min-h-screen flex flex-col"
  style={`background-color: ${siteConfig.theme.colors.background}`}
>
  <Header />
  <main class="flex-1 py-8 sm:py-12 w-full min-w-0 overflow-x-hidden">
    <div class="px-4 sm:px-6 md:px-12 w-full">
      <slot />
    </div>
  </main>
  <Footer />

  {/* 滚动动画脚本 */}
  <script src="../scripts/scroll-reveal.ts"></script>
</body>
</html>
