---
import '../styles/global.css';
import '../styles/animations.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../site.config';

interface Props {
  title?: string;
  description?: string;
}

// 优先使用传入的 props，否则使用配置文件中的默认值
const { 
  title = siteConfig.title,
  description = siteConfig.description 
} = Astro.props;

// 页面标题格式：页面标题 · 站点名
const pageTitle = title === siteConfig.title 
  ? siteConfig.title 
  : `${title} · ${siteConfig.title}`;
---

<!DOCTYPE html>
<html lang={siteConfig.language}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>
  <link rel="icon" type="image/svg+xml" href={siteConfig.favicon} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body
  class="min-h-screen flex flex-col overflow-x-hidden"
  style={`background-color: ${siteConfig.theme.colors.background}`}
>
  <Header />
  <main class="flex-1 py-8 sm:py-12 w-full min-w-0">
    <div class="px-4 sm:px-6 md:px-12 w-full max-w-full">
      <slot />
    </div>
  </main>
  <Footer />

  <!-- 滚动动画脚本 -->
  <script src="../scripts/scroll-reveal.ts"></script>
</body>
</html>
