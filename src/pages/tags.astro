---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { pinyin } from 'pinyin-pro';

const posts = await getCollection('posts');

// 按标签分组
const postsByTag = posts.reduce((acc, post) => {
  post.data.tags.forEach(tag => {
    if (!acc[tag]) {
      acc[tag] = [];
    }
    acc[tag].push(post);
  });
  return acc;
}, {} as Record<string, typeof posts>);

// 获取首字母（支持英文和中文拼音）
function getFirstLetter(str: string): string {
  const firstChar = str.charAt(0);
  
  // 如果是英文字母，直接返回大写
  if (/^[a-zA-Z]$/.test(firstChar)) {
    return firstChar.toUpperCase();
  }
  
  // 如果是中文，获取拼音首字母
  if (/^[\u4e00-\u9fa5]$/.test(firstChar)) {
    const py = pinyin(firstChar, { toneType: 'none', type: 'first' });
    return py.charAt(0).toUpperCase();
  }
  
  // 其他字符归到 # 组
  return '#';
}

// 按字母分组标签
const groupedTags: Record<string, [string, typeof posts][]> = {};
Object.entries(postsByTag)
  .sort((a, b) => a[0].localeCompare(b[0], 'zh-CN'))
  .forEach(([tag, tagPosts]) => {
    const letter = getFirstLetter(tag);
    if (!groupedTags[letter]) {
      groupedTags[letter] = [];
    }
    groupedTags[letter].push([tag, tagPosts]);
  });

// 获取排序后的字母（A-Z 在前，# 在最后）
const sortedLetters = Object.keys(groupedTags).sort((a, b) => {
  if (a === '#') return 1;
  if (b === '#') return -1;
  return a.localeCompare(b);
});
---

<BaseLayout title="标签">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    {/* 标题 - 入场动画 */}
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-serif text-[#1A1A1A] mb-12 md:mb-16 animate-fade-in-up">
      标签
    </h1>

    {/* 标签统计 */}
    <p class="text-[#6B6B6B] mb-12 reveal">
      共 {Object.keys(postsByTag).length} 个标签
    </p>

    {/* 字母导航 */}
    <nav class="flex flex-wrap gap-2 mb-12 reveal">
      {sortedLetters.map((letter) => (
        <a
          href={`#tag-${letter}`}
          class="w-10 h-10 flex items-center justify-center text-sm font-medium text-[#6B6B6B] hover:text-[#E74C3C] hover:bg-[#F5F5F5] rounded transition-all duration-300"
        >
          {letter}
        </a>
      ))}
    </nav>

    {/* 标签列表 - 按字母分组 */}
    <div class="space-y-12">
      {sortedLetters.map((letter, letterIndex) => (
        <section id={`tag-${letter}`} class="reveal">
          {/* 字母标题 */}
          <h2 class="text-2xl font-serif text-[#1A1A1A] mb-6 pb-2 border-b border-[#E8E8E8]">
            {letter}
          </h2>
          
          {/* 该字母下的标签 */}
          <div class="flex flex-wrap gap-3 mt-4">
            {groupedTags[letter].map(([tag, tagPosts], index) => (
              <a
                href={`/tags/${encodeURIComponent(tag)}`}
                class="group inline-flex items-center gap-2 px-4 py-2 bg-white border border-[#E8E8E8] rounded-full text-sm text-[#6B6B6B] hover:border-[#E74C3C] hover:text-[#E74C3C] transition-all duration-300"
                style={`animation-delay: ${(letterIndex * 0.1) + (index * 0.05)}s;`}
              >
                <span>{tag}</span>
                <span class="text-xs px-2 py-0.5 bg-[#F5F5F5] group-hover:bg-[#E74C3C] group-hover:text-white rounded-full transition-colors duration-300">
                  {tagPosts.length}
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    {/* 无标签提示 */}
    {sortedLetters.length === 0 && (
      <section class="text-center py-20 reveal">
        <p class="text-[#6B6B6B] text-lg">暂无标签</p>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
